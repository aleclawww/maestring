{
  "name": "maestring",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "seed": "tsx scripts/seed-aws-saa.ts",
    "seed:pool": "tsx scripts/seed-question-pool.ts",
    "seed:load": "tsx scripts/load-question-pool.ts",
    "reset-dev": "tsx scripts/reset-dev.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > types/supabase-generated.ts",
    "db:diff": "supabase db diff",
    "setup": "npm install && supabase start && supabase db push && npm run db:types && npm run seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@react-email/components": "^0.0.22",
    "@sentry/nextjs": "^8.19.0",
