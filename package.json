    "@supabase/supabase-js": "2.45.4",
    "@upstash/ratelimit": "^2.0.1",
    "@upstash/redis": "^1.32.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "3.6.0",
    "gray-matter": "^4.0.3",
    "jose": "^5.6.3",
    "nanoid": "^5.0.7",
    "next": "^14.2.35",
    "next-mdx-remote": "^6.0.0",
    "openai": "^4.52.7",
    "pdf-parse": "^1.1.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "posthog-js": "^1.148.0",
    "posthog-node": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^2.1.5",
    "resend": "^3.4.0",
    "stripe": "^16.2.0",
    "tailwind-merge": "^2.4.0",
    "tiktoken": "^1.0.15",
    "ts-fsrs": "^4.3.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
