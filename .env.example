# ============================================
# MAESTRING — Environment Variables
# ============================================
# Copy this file to .env.local and fill in real values.

# -- Supabase ----------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -- App URLs (use NEXT_PUBLIC_APP_URL in code; SITE_URL kept for SEO/metadata) --
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -- AI ----------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -- Stripe ------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# -- Upstash Redis (rate limiting, fail-open) --
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional rate-limit overrides (per-minute, per-user)
RATE_LIMIT_AI_EXPLANATIONS=20
RATE_LIMIT_API_GENERAL=60
RATE_LIMIT_PDF_UPLOAD=10
RATE_LIMIT_STRIPE=10

# -- Resend (transactional email) --------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@maestring.com
RESEND_FROM_NAME=Maestring

# -- PostHog (product analytics) ---------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -- Sentry (error monitoring) -----------------
NEXT_PUBLIC_SENTRY_DSN=

# -- Auth / admin ------------------------------
ADMIN_EMAILS=admin@maestring.com

# -- Cron (Vercel Cron uses Authorization: Bearer $CRON_SECRET) --
CRON_SECRET=

# -- Magic Links (JWT signing key) -------------
MAGIC_LINK_SECRET=
